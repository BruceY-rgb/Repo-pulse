# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/repo_pulse

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRATION=7d
JWT_REFRESH_EXPIRATION=30d

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# GitHub API (for repository sync)
GITHUB_TOKEN=

# GitLab OAuth
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_CALLBACK_URL=http://localhost:3001/auth/gitlab/callback

# GitLab API (for repository sync)
GITLAB_TOKEN=

# AI Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# AI Default Settings
AI_DEFAULT_PROVIDER=openai
AI_DEFAULT_MODEL=gpt-4o-mini
AI_FALLBACK_CHAIN=openai,anthropic,ollama

# App Configuration
APP_PORT=3001
# API_URL: 后端 API 的公开访问地址，用于生成 Webhook 回调 URL
API_URL=http://localhost:3001
# FRONTEND_URL: 前端应用的访问地址，用于 OAuth 回调重定向和 CORS 配置
FRONTEND_URL=http://localhost:5173

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
